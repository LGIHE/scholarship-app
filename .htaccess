Options -Indexes

RewriteEngine On

# Redirect all requests to the Laravel public directory
RewriteRule ^$ public/ [L]
RewriteRule ^((?!public/).*)$ public/$1 [L,NC]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-SSL} !on
RewriteCond %{HTTP_HOST} ^scholarships\.lgfug\.org$ [OR]
RewriteCond %{HTTP_HOST} ^www\.scholarships\.lgfug\.org$
RewriteRule ^/?$ "https\:\/\/scholarships\.lgfug\.org\/" [R=301,L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
